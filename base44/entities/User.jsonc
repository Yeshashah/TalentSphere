{
  "name": "User",
  "type": "object",
  "properties": {
    "role": {
      "type": "string",
      "enum": [
        "user",
        "candidate",
        "company",
        "admin"
      ],
      "default": "user"
    },
    "profile_setup_complete": {
      "type": "boolean",
      "default": false,
      "description": "Whether the user has completed their candidate or company profile setup"
    }
  }
}